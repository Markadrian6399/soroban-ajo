# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ajo

# Redis (for job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@ajo.app

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Push Notifications (Firebase)
FCM_SERVER_KEY=

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
PORT=3001
NODE_ENV=development
