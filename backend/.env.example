# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ajo

# Auth
JWT_SECRET=

# Redis (for job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@ajo.app

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Push Notifications (Firebase)
FCM_SERVER_KEY=

# Soroban
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_CONTRACT_ID=
# Fee-paying "keeper" key used to submit permissionless execute_payout calls
# (holds no group funds — the contract transfers from its own escrow balance)
SOROBAN_KEEPER_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000

# Server
PORT=3001
NODE_ENV=development
